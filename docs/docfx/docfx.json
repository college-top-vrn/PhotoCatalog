{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../src",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "src": ".",
        "exclude": ["_site/**", "**/bin/**", "**/obj/**"]
      },
      {
        "files": ["../**/*.md"],
        "src": "..",
        "exclude": ["docfx/_site/**", "**/bin/**", "**/obj/**"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "PhotoCatalog",
      "_appTitle": "PhotoCatalog Documentation",
      "_enableSearch": true,
      "pdf": true
    }
  }
}
